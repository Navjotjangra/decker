---
// components
import Text from "../elements/Text.astro";
import NavBar from "./NavBar.astro";
import SocialLinks from "../elements/SocialLinks.astro";

// header content -> modify here!
const {
    role = "AI/ML Engineer & Data Science Student",
    name = "Navjot Jangra",
    status = "Open to opportunities"
} = Astro.props;

---

<header class="flex flex-col gap-24 md:pt-56 pt-16 bg-base-950 md:sticky md:top-0 z-50">
    <div class="md:px-32 px-16 flex flex-row gap-16 items-center">
            <div class="flex flex-col gap-24 md:items-start justify-center items-center">
                <div class="flex flex-col md:text-left text-center">
                    <Text variant={'normal'} class="text-base-700">// {role}</Text>
                    <Text variant={'xl'}>{name}</Text>
                </div>
                <SocialLinks />
            </div>
            <div class="bg-base-950 drop-shadow-md p-8">
                <Text variant={'sm'} class="text-base-200">{status}</Text>
            </div>
        </div>
    </div>
    <NavBar />
</header>